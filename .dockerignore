# Docker ignore — prevents secrets, deps, and cache from being baked into images

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
**/.pytest_cache/
**/venv/
**/.venv/
**/*.egg-info/

# Node
**/node_modules/

# Environment & secrets (NEVER bake into image)
**/.env
**/.env.*
!**/.env.example

# Git
**/.git/
**/.gitignore

# Logs and temp files
**/*.log
**/gemini_out.txt
**/geminilist.txt
**/git_diff.txt
**/build_output.txt

# IDE
**/.vscode/
**/.idea/

# OS
**/Thumbs.db
**/.DS_Store
