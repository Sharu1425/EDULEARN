# Backend Environment Variables Template
# Copy this file to `.env` or set these variables in your hosting provider's dashboard
# DO NOT commit your actual .env file with secrets!

# Database Configuration (Use MongoDB Atlas for production)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/edulearn
DB_NAME=edulearn

# Cross-Origin Resource Sharing (CORS) - Set this to your frontend's production URL
FRONTEND_URL=https://your-frontend-app.vercel.app

# Security Secrets (Use random, secure cryptographic strings for production)
SECRET_KEY=your_production_secret_key_here
SESSION_SECRET=your_production_session_secret_here

# AI Service Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# External Services (Hackerearth Code Execution)
HACKEREARTH_CLIENT_SECRET=your_hackerearth_client_secret_here
